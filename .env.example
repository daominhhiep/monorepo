# Postgres
POSTGRES_USER=base
POSTGRES_PASSWORD=base
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Service-specific DBs
USER_POSTGRES_URL=postgres://base:base@localhost:5432/base_user?sslmode=disable

# NATS
NATS_URL=nats://localhost:4222

# JWT
JWT_SECRET=change-me-in-prod-min-32-chars-long-please
JWT_ISSUER=base-microservice
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Service ports
USER_HTTP_LISTEN=:8001

# BFF ports
WEBAPP_BFF_LISTEN=:8082
WEBAPP_WEB_PORT=3000

# Backend URLs (BFF → services)
WEBAPP_BACKEND_USER_URL=http://localhost:8001

# Cookie / Session
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Observability (optional — leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
LOG_LEVEL=info
