# Postgres (docker-compose bootstrap)
POSTGRES_USER=base
POSTGRES_PASSWORD=base
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# user service — BASE_USER_<FLAG> (flag dashes → underscores, uppercase)
BASE_USER_HTTP_LISTEN=:8001
BASE_USER_DB_POSTGRES_URL=postgres://base:base@localhost:5432/base_user?sslmode=disable
BASE_USER_DB_AUTO_MIGRATE=true
BASE_USER_NATS_URL=nats://localhost:4222
BASE_USER_JWT_SECRET=change-me-in-prod-min-32-chars-long-please
BASE_USER_JWT_ISSUER=base-microservice
BASE_USER_JWT_ACCESS_TTL=15m
BASE_USER_JWT_REFRESH_TTL=720h
BASE_USER_OBS_LOG_LEVEL=info

# webapp BFF — BASE_WEBAPP_<FLAG>. JWT_SECRET must match user service.
BASE_WEBAPP_HTTP_LISTEN=:8082
BASE_WEBAPP_BACKEND_USER_URL=http://localhost:8001
BASE_WEBAPP_COOKIE_DOMAIN=localhost
BASE_WEBAPP_COOKIE_SECURE=false
BASE_WEBAPP_COOKIE_SAMESITE=lax
BASE_WEBAPP_JWT_SECRET=change-me-in-prod-min-32-chars-long-please
BASE_WEBAPP_JWT_ISSUER=base-microservice
BASE_WEBAPP_JWT_ACCESS_TTL=15m
BASE_WEBAPP_JWT_REFRESH_TTL=720h
BASE_WEBAPP_OBS_LOG_LEVEL=info

# Vite dev server
WEBAPP_WEB_PORT=3000

# Observability (optional — leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
